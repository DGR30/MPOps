pipeline {
    agent any

    stages {

        stage('Build Docker Image') {
            steps {
                script {
                    docker.build("mpops-demo")
                }
            }
        }

        stage('Run Pipeline Inside Container') {
            steps {
                script {
                    docker.image("mpops-demo").inside {
                        sh 'python scripts/train.py'
                        sh 'python scripts/evaluate.py'
                        sh 'python scripts/mpops_diff.py'
                    }
                }
            }
        }
    }
}
