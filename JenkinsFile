pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                git 'https://github.com/DGR30/MPOps.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                script {
                    docker.build("mpops-demo")
                }
            }
        }

        stage('Run Pipeline Inside Container') {
            steps {
                script {
                    docker.image("mpops-demo").inside {
                        sh 'python scripts/train.py'
                        sh 'python scripts/evaluate.py'
                        sh 'python scripts/diff.py'
                    }
                }
            }
        }
    }
}